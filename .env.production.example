DEPLOY_PATH=/opt/awardsferm

# На VPS с системным nginx на :443/:80 контейнер фронта публикуйте на свободный порт (часто 55502).
FRONTEND_PORT=55502
# Должен совпадать с upstream API в системном nginx (127.0.0.1:55501).
API_PORT=55501

# OAuth-токен РСЯ (опционально). Можно также положить в profiles/rsya-token.txt на сервере.
# RSYA_OAUTH_TOKEN=

# Пусто = same-origin: браузер ходит на /api через nginx фронта.
# VITE_API_URL=
